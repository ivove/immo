@model Immo.Data.Entities.AppSettings

@{
    ViewData["Title"] = "Global Settings";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white p-4 border-0">
                    <h2 class="h4 mb-0 fw-bold">
                        <i class="bi bi-gear-fill me-2"></i> Global Configuration
                    </h2>
                </div>
                <div class="card-body p-4 p-md-5">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-5">
                            <h5 class="fw-bold mb-3 text-dark">
                                <i class="bi bi-clock-history text-primary me-2"></i> Crawler Frequency
                            </h5>
                            <div class="bg-light p-4 rounded-4">
                                <label asp-for="RecrawlAfterDays" class="form-label fw-semibold">Recrawl Interval (Days)</label>
                                <div class="input-group">
                                    <input asp-for="RecrawlAfterDays" type="number" class="form-control form-control-lg border-0 shadow-none" min="1" max="30" />
                                    <span class="input-group-text bg-white border-0 text-muted">days</span>
                                </div>
                                <div class="form-text mt-2">Number of days to wait before recrawling a property to check for updates or status changes.</div>
                                <span asp-validation-for="RecrawlAfterDays" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-5">
                            <h5 class="fw-bold mb-3 text-dark">
                                <i class="bi bi-arrow-repeat text-success me-2"></i> Cycle Frequency
                            </h5>
                            <div class="bg-light p-4 rounded-4">
                                <label asp-for="CrawlIntervalHours" class="form-label fw-semibold">Cycle Wait Time (Hours)</label>
                                <div class="input-group">
                                    <input asp-for="CrawlIntervalHours" type="number" class="form-control form-control-lg border-0 shadow-none" min="1" max="168" />
                                    <span class="input-group-text bg-white border-0 text-muted">hours</span>
                                </div>
                                <div class="form-text mt-2">How long the crawler should wait after finishing a complete cycle before starting the next one.</div>
                                <span asp-validation-for="CrawlIntervalHours" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-5">
                            <h5 class="fw-bold mb-3 text-dark">
                                <i class="bi bi-globe text-info me-2"></i> Timezone Settings
                            </h5>
                            <div class="bg-light p-4 rounded-4">
                                <label asp-for="PreferredTimezone" class="form-label fw-semibold">Display Timezone</label>
                                <select asp-for="PreferredTimezone" class="form-select form-select-lg border-0 shadow-none"
                                        asp-items="@(new SelectList(ViewBag.Timezones, "Id", "DisplayName"))">
                                </select>
                                <div class="form-text mt-2">All dates and times displayed across the system will be adjusted to this timezone.</div>
                                <span asp-validation-for="PreferredTimezone" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-5">
                            <h5 class="fw-bold mb-3 text-dark">
                                <i class="bi bi-star-fill text-warning me-2"></i> Recency Highlights
                            </h5>
                            <div class="bg-light p-4 rounded-4">
                                <label asp-for="NewOrUpdatedThresholdDays" class="form-label fw-semibold">New/Updated Highlight Threshold (Days)</label>
                                <div class="input-group">
                                    <input asp-for="NewOrUpdatedThresholdDays" type="number" class="form-control form-control-lg border-0 shadow-none" min="1" max="90" />
                                    <span class="input-group-text bg-white border-0 text-muted">days</span>
                                </div>
                                <div class="form-text mt-2">Properties added or updated within this number of days will be highlighted with dynamic badges in the property listings.</div>
                                <span asp-validation-for="NewOrUpdatedThresholdDays" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-5">
                            <h5 class="fw-bold mb-3 text-dark">
                                <i class="bi bi-tag-fill text-danger me-2"></i> Sold Keywords
                            </h5>
                            <div class="bg-light p-4 rounded-4">
                                <label asp-for="SoldKeywords" class="form-label fw-semibold">Keywords (Comma-separated)</label>
                                <textarea asp-for="SoldKeywords" class="form-control border-0 shadow-none" rows="3" placeholder="e.g. verkocht, sold, compromis getekend"></textarea>
                                <div class="form-text mt-2">Properties containing any of these words will be marked as <strong>SOLD</strong>.</div>
                                <span asp-validation-for="SoldKeywords" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-5">
                            <h5 class="fw-bold mb-3 text-dark">
                                <i class="bi bi-bookmark-star-fill text-warning me-2"></i> Under Option Keywords
                            </h5>
                            <div class="bg-light p-4 rounded-4">
                                <label asp-for="UnderOptionKeywords" class="form-label fw-semibold">Keywords (Comma-separated)</label>
                                <textarea asp-for="UnderOptionKeywords" class="form-control border-0 shadow-none" rows="3" placeholder="e.g. optie, under option, gereserveerd"></textarea>
                                <div class="form-text mt-2">Properties containing any of these words will be marked as <strong>UNDER OPTION</strong>.</div>
                                <span asp-validation-for="UnderOptionKeywords" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold py-3 shadow-sm">
                                <i class="bi bi-save me-2"></i> Save Configuration
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
