@model Immo.Data.Entities.ParserConfig

@{
    ViewData["Title"] = "Parser Configuration";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Agencies</a></li>
            <li class="breadcrumb-item"><a asp-action="Edit" asp-route-id="@Model.AgencyId">Edit Agency</a></li>
            <li class="breadcrumb-item active" aria-current="page">Parser Configuration</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h2 class="fw-bold mb-4">Parser Configuration</h2>
            
            <form asp-action="EditParserConfig">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="AgencyId" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <!-- General Selectors -->
                    <div class="col-md-6">
                        <h4 class="h5 fw-bold mb-3">Main Field Selectors (XPath)</h4>
                        
                        <div class="mb-3">
                            <label asp-for="TitleSelector" class="form-label">Title Selector</label>
                            <input asp-for="TitleSelector" class="form-control" placeholder="//h1" />
                            <span asp-validation-for="TitleSelector" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="PriceSelector" class="form-label">Price Selector</label>
                            <input asp-for="PriceSelector" class="form-control" placeholder="//div[contains(class, 'price')]" />
                            <span asp-validation-for="PriceSelector" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="BedroomSelector" class="form-label">Bedroom Selector</label>
                            <input asp-for="BedroomSelector" class="form-control" />
                            <span asp-validation-for="BedroomSelector" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="DescriptionSelector" class="form-label">Description Selector</label>
                            <input asp-for="DescriptionSelector" class="form-control" />
                            <span asp-validation-for="DescriptionSelector" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="ImageSelector" class="form-label">Image Selector</label>
                            <input asp-for="ImageSelector" class="form-control" />
                            <span asp-validation-for="ImageSelector" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="AddressSelector" class="form-label">Address Selector</label>
                            <input asp-for="AddressSelector" class="form-control" />
                            <span asp-validation-for="AddressSelector" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ExternalIdPattern" class="form-label">External ID Pattern (Regex on URL)</label>
                            <input asp-for="ExternalIdPattern" class="form-control" placeholder="/(\d+)$" />
                            <span asp-validation-for="ExternalIdPattern" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Spec Table Logic -->
                    <div class="col-md-6">
                        <h4 class="h5 fw-bold mb-3">Specification Table (Key-Value)</h4>
                        
                        <div class="mb-3">
                            <label asp-for="SpecContainerSelector" class="form-label">Spec Row Selector (e.g. //tr or //dl/div)</label>
                            <input asp-for="SpecContainerSelector" class="form-control" />
                            <span asp-validation-for="SpecContainerSelector" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label asp-for="SpecLabelSelector" class="form-label">Label Selector (.//td[1])</label>
                                <input asp-for="SpecLabelSelector" class="form-control" />
                                <span asp-validation-for="SpecLabelSelector" class="text-danger"></span>
                            </div>
                            <div class="col-6 mb-3">
                                <label asp-for="SpecValueSelector" class="form-label">Value Selector (.//td[2])</label>
                                <input asp-for="SpecValueSelector" class="form-control" />
                                <span asp-validation-for="SpecValueSelector" class="text-danger"></span>
                            </div>
                        </div>

                        <hr class="my-4" />
                        
                        <h4 class="h5 fw-bold mb-3">Label Mappings (Contains Match)</h4>
                        
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label asp-for="BedroomLabel" class="form-label">Bedrooms Label</label>
                                <input asp-for="BedroomLabel" class="form-control" placeholder="Slaapkamers" />
                                <span asp-validation-for="BedroomLabel" class="text-danger"></span>
                            </div>
                            <div class="col-6 mb-3">
                                <label asp-for="CountBedrooms" class="form-label">Count Bedrooms</label>
                                <input asp-for="CountBedrooms" type="checkbox" class="form-check-input" />
                                <span asp-validation-for="CountBedrooms" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label asp-for="LivingAreaLabel" class="form-label">Living Area Label</label>
                                <input asp-for="LivingAreaLabel" class="form-control" placeholder="Bewoonbare opp" />
                                <span asp-validation-for="LivingAreaLabel" class="text-danger"></span>
                            </div>
                            <div class="col-6 mb-3">
                                <label asp-for="PlotAreaLabel" class="form-label">Plot Area Label</label>
                                <input asp-for="PlotAreaLabel" class="form-control" placeholder="Grondopp" />
                                <span asp-validation-for="PlotAreaLabel" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label asp-for="EpcLabel" class="form-label">EPC Label</label>
                                <input asp-for="EpcLabel" class="form-control" placeholder="EPC" />
                                <span asp-validation-for="EpcLabel" class="text-danger"></span>
                            </div>
                            <div class="col-6 mb-3">
                                <label asp-for="ReferenceLabel" class="form-label">Reference/External ID Label</label>
                                <input asp-for="ReferenceLabel" class="form-control" placeholder="Referentie" />
                                <span asp-validation-for="ReferenceLabel" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="AddressLabel" class="form-label">Combined Address Label</label>
                            <input asp-for="AddressLabel" class="form-control" placeholder="Adres" />
                            <span asp-validation-for="AddressLabel" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label asp-for="ZipCodeLabel" class="form-label">Zip Code Label</label>
                                <input asp-for="ZipCodeLabel" class="form-control" placeholder="Postcode" />
                                <span asp-validation-for="ZipCodeLabel" class="text-danger"></span>
                            </div>
                            <div class="col-6 mb-3">
                                <label asp-for="CityLabel" class="form-label">City Label</label>
                                <input asp-for="CityLabel" class="form-control" placeholder="Stad" />
                                <span asp-validation-for="CityLabel" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="PriceLabel" class="form-label">Price Label</label>
                            <input asp-for="PriceLabel" class="form-control" placeholder="Prijs" />
                            <span asp-validation-for="PriceLabel" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.AgencyId" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save Configuration</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
