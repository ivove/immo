@model IEnumerable<Immo.Data.Entities.Agency>

@{
    ViewData["Title"] = "Agencies";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold text-dark">Agencies</h1>
            <p class="text-muted">Manage real estate agencies and their crawling rules.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Export" class="btn btn-outline-secondary btn-lg shadow-sm" title="Export agencies to JSON">
                <i class="bi bi-download me-1"></i> Export
            </a>
            <form asp-action="Import" method="post" enctype="multipart/form-data" class="d-inline">
                <label for="importFile" class="btn btn-outline-secondary btn-lg shadow-sm mb-0" title="Import agencies from JSON" style="cursor: pointer;">
                    <i class="bi bi-upload me-1"></i> Import
                </label>
                <input type="file" id="importFile" name="importFile" class="d-none" accept=".json" onchange="this.form.submit()" />
            </form>
            <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
                <i class="bi bi-plus-lg me-2"></i> Add Agency
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4 py-3 border-0">Agency Domain</th>
                        <th class="px-4 py-3 border-0">Crawler Rules</th>
                        <th class="px-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="px-4 py-3">
                                <div class="fw-semibold text-dark">@item.AgencyDomain</div>
                                <small class="text-muted">ID: @item.Id</small>
                            </td>
                            <td class="px-4 py-3">
                                <span class="badge rounded-pill bg-info-subtle text-info border border-info-subtle">
                                    @item.AgencyListingChecks.Count Rules
                                </span>
                                @if (item.ParserConfig != null)
                                {
                                    <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle ms-1">
                                        <i class="bi bi-check-circle"></i> Parser OK
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-warning-subtle text-warning border border-warning-subtle ms-1">
                                        <i class="bi bi-exclamation-triangle"></i> No Parser
                                    </span>
                                }
                            </td>
                            <td class="px-4 py-3 text-end">
                                <div class="d-flex align-items-center justify-content-end gap-2">
                                    @if (item.CrawlRequestedAt.HasValue)
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle" title="Crawl queued at @item.CrawlRequestedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")">
                                            <i class="bi bi-hourglass-split me-1"></i> Pending
                                        </span>
                                    }
                                    <div class="btn-group">
                                        <form asp-action="RequestCrawl" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-primary" title="Run crawl now" @(item.CrawlRequestedAt.HasValue ? "disabled" : "")>
                                                <i class="bi bi-play-fill"></i>
                                            </button>
                                        </form>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Details">
                                            <i class="bi bi-info-circle"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any()) {
                        <tr>
                            <td colspan="3" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="bi bi-building-exclamation display-1 mb-3 d-block"></i>
                                    <p class="fs-5">No agencies found.</p>
                                    <a asp-action="Create" class="btn btn-link">Add your first agency</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
