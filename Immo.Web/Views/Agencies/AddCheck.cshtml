@{
    ViewData["Title"] = "Add Crawler Rule";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Agencies</a></li>
            <li class="breadcrumb-item"><a asp-action="Edit" asp-route-id="@ViewBag.AgencyId">Edit Agency</a></li>
            <li class="breadcrumb-item active" aria-current="page">Add Rule</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="fw-bold mb-4">Add Crawler Rule</h2>
                    
                    <form asp-action="AddCheck">
                        <input type="hidden" name="agencyId" value="@ViewBag.AgencyId" />
                        
                        <div class="mb-4">
                            <label for="possibilitiesRaw" class="form-label fw-semibold">URL Possibilities (One per line)</label>
                            <textarea id="possibilitiesRaw" name="possibilitiesRaw" class="form-control" rows="6" placeholder="te-koop&#10;huis&#10;villa" required></textarea>
                            <div class="form-text mt-2">
                                For a link to be extracted, it must contain <b>all</b> of the specified strings. 
                                Each line represents a string that must be present in the URL.
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Add Rule</button>
                            <a asp-action="Edit" asp-route-id="@ViewBag.AgencyId" class="btn btn-link text-muted">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
