@model Immo.Data.Entities.Agency

@{
    ViewData["Title"] = "Agency Details";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Agencies</a></li>
            <li class="breadcrumb-item active" aria-current="page">Agency Details</li>
        </ol>
    </nav>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-5 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <h2 class="fw-bold mb-1">@Model.AgencyDomain</h2>
                            <small class="text-muted">Agency ID: @Model.Id</small>
                        </div>
                        @if (Model.IsSuspended)
                        {
                            <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle">
                                <i class="bi bi-pause-fill"></i> Suspended
                            </span>
                        }
                        else
                        {
                            <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle">
                                <i class="bi bi-check-circle-fill"></i> Active
                            </span>
                        }
                    </div>

                    <div class="mb-4">
                        <label class="fw-semibold text-muted small d-block mb-1">Pagination Selector</label>
                        @if (!string.IsNullOrEmpty(Model.PaginationSelector))
                        {
                            <code class="fs-6 bg-light p-2 rounded d-block border">@Model.PaginationSelector</code>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">None configured (no pagination support)</span>
                        }
                    </div>

                    <div class="mb-4">
                        <label class="fw-semibold text-muted small d-block mb-1">Notes</label>
                        @if (!string.IsNullOrEmpty(Model.Notes))
                        {
                            <p class="mb-0 text-dark bg-light p-3 rounded border">@Model.Notes</p>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">No notes recorded.</span>
                        }
                    </div>

                    <hr />

                    <div class="d-grid gap-2 mb-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                            <i class="bi bi-pencil me-2"></i>Edit Agency Details
                        </a>
                    </div>
                    <div class="d-grid gap-2 mb-2">
                        <a asp-action="EditParserConfig" asp-route-agencyId="@Model.Id" class="btn btn-outline-info">
                            <i class="bi bi-gear me-2"></i>Configure Parser
                        </a>
                    </div>
                    <div class="d-grid gap-2 mb-2">
                        <form asp-action="RequestCrawl" asp-route-id="@Model.Id" method="post" class="d-grid">
                            <button type="submit" class="btn btn-outline-primary" @(Model.CrawlRequestedAt.HasValue || Model.IsSuspended ? "disabled" : "")>
                                <i class="bi bi-play-fill me-2"></i>Run Crawl Now
                            </button>
                        </form>
                    </div>
                    <div class="d-grid gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h3 class="fw-bold mb-4">Crawling Rules</h3>
                    
                    @if (!Model.AgencyListingChecks.Any())
                    {
                        <div class="text-center py-4 bg-light rounded-3 border border-dashed">
                            <p class="text-muted mb-0">No crawling rules defined for this agency yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush border-top">
                            @foreach (var check in Model.AgencyListingChecks)
                            {
                                <div class="list-group-item px-0 py-3">
                                    <div class="fw-bold text-dark mb-2">Rule ID: @check.Id</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var pos in check.UrlPosibilities)
                                        {
                                            <span class="badge bg-light text-dark border">@pos</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h3 class="fw-bold mb-3">Parser Configuration</h3>
                    
                    @if (Model.ParserConfig == null)
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            This agency has no parser configuration! Properties will not be extracted from pages.
                            <div class="mt-2">
                                <a asp-action="EditParserConfig" asp-route-agencyId="@Model.Id" class="btn btn-sm btn-warning">
                                    Create Config
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-borderless align-middle mb-0">
                                <tbody>
                                    <tr>
                                        <td class="fw-semibold text-muted" style="width: 30%;">Title Selector</td>
                                        <td><code>@Model.ParserConfig.TitleSelector</code></td>
                                    </tr>
                                    <tr>
                                        <td class="fw-semibold text-muted">Price Selector</td>
                                        <td><code>@Model.ParserConfig.PriceSelector</code></td>
                                    </tr>
                                    <tr>
                                        <td class="fw-semibold text-muted">Description Selector</td>
                                        <td><code>@Model.ParserConfig.DescriptionSelector</code></td>
                                    </tr>
                                    <tr>
                                        <td class="fw-semibold text-muted">Image Selector</td>
                                        <td><code>@Model.ParserConfig.ImageSelector</code></td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(Model.ParserConfig.SpecContainerSelector))
                                    {
                                        <tr>
                                            <td class="fw-semibold text-muted">Spec Container</td>
                                            <td><code>@Model.ParserConfig.SpecContainerSelector</code></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
